@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if (NOT gempba_FIND_COMPONENTS)
    set(gempba_FIND_COMPONENTS mt)
    set(gempba_FIND_REQUIRED_mt TRUE)
endif ()

# Mutual-exclusion guard: gempba's flavors share top-level symbols
# (gempba::shutdown, gempba::get_load_balancer, ...). Linking two flavors into
# one binary is an ODR violation. The Config refuses the combination up front
# so the consumer sees a clear diagnostic instead of a confusing link error.
list(FIND gempba_FIND_COMPONENTS "mt" _gempba_has_mt)
list(FIND gempba_FIND_COMPONENTS "mpi" _gempba_has_mpi)
if (NOT _gempba_has_mt EQUAL -1 AND NOT _gempba_has_mpi EQUAL -1)
    set(gempba_FOUND FALSE)
    set(gempba_NOT_FOUND_MESSAGE
        "gempba 'mt' and 'mpi' components cannot both be requested — they share "
        "mode-agnostic top-level symbols and cannot coexist in one binary. "
        "Pick one component per target.")
    return()
endif ()
unset(_gempba_has_mt)
unset(_gempba_has_mpi)

find_dependency(fmt REQUIRED)
find_dependency(Threads REQUIRED)

if (@GEMPBA_HWLOC@)
    find_dependency(PkgConfig REQUIRED)
    pkg_check_modules(HWLOC REQUIRED IMPORTED_TARGET hwloc)
endif ()

foreach (_gempba_comp IN LISTS gempba_FIND_COMPONENTS)
    if (_gempba_comp STREQUAL "mt")
        if (EXISTS "${CMAKE_CURRENT_LIST_DIR}/gempba_mt-targets.cmake")
            include("${CMAKE_CURRENT_LIST_DIR}/gempba_mt-targets.cmake")
            set(gempba_mt_FOUND TRUE)
        else ()
            set(gempba_mt_FOUND FALSE)
        endif ()
    elseif (_gempba_comp STREQUAL "mpi")
        if (EXISTS "${CMAKE_CURRENT_LIST_DIR}/gempba_mpi-targets.cmake")
            find_dependency(MPI REQUIRED)
            include("${CMAKE_CURRENT_LIST_DIR}/gempba_mpi-targets.cmake")
            set(gempba_mpi_FOUND TRUE)
        else ()
            set(gempba_mpi_FOUND FALSE)
        endif ()
    else ()
        set(gempba_${_gempba_comp}_FOUND FALSE)
    endif ()
endforeach ()
unset(_gempba_comp)

check_required_components(gempba)
